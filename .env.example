# Copy to .env to enable the LLM planner/synthesizer. Optional — the agent works without it.
ANTHROPIC_API_KEY=
# Model used to plan steps and phrase the final answer (it can only choose from the
# registered tools, and the answer is verified against the step results).
AGENT_MODEL=claude-haiku-4-5-20251001
# Safety cap: the executor refuses to run more than this many steps.
MAX_STEPS=6
